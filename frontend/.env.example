# Used by the frontend at runtime (import.meta.env.VITE_API_BASE_URL).
# Leave unset to default to "/api" and use the Vite dev proxy below.
VITE_API_BASE_URL=

# Used only by vite.config.ts during `npm run dev` to proxy /api/* requests
# to your backend, avoiding CORS issues in local development.
VITE_API_PROXY_TARGET=http://localhost:4000
